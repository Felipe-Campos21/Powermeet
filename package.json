{
  "name": "powermeet",
  "version": "1.0.0",
  "description": "PowerMeet - Conciliação Bancária Inteligente",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "dependencies": {
    "sql.js": "^1.12.0",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.powermeet.app",
    "productName": "PowerMeet",
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "server/**/*",
      "public/**/*"
    ]
  }
}
